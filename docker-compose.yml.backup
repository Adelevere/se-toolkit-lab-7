services:
  postgres:
    image: harbor.pg.innopolis.university/docker-hub-cache/postgres:18.3-alpine
    container_name: se-toolkit-lab-7-postgres-1
    environment:
      - POSTGRES_DB=${POSTGRES_DB:-db-lab-7}
      - POSTGRES_USER=${POSTGRES_USER:-postgres}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-postgres}
    ports:
      - "${POSTGRES_HOST_PORT:-42004}:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres}"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - lms-network
    restart: unless-stopped

  backend:
    build:
      context: .
      dockerfile: backend/Dockerfile
    container_name: se-toolkit-lab-7-backend-1
    environment:
      - DATABASE_URL=postgresql://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-postgres}@postgres:5432/${POSTGRES_DB:-db-lab-7}
      - LMS_API_KEY=${LMS_API_KEY}
      - AUTOCHECKER_API_URL=${AUTOCHECKER_API_URL}
      - AUTOCHECKER_EMAIL=${AUTOCHECKER_EMAIL}
      - AUTOCHECKER_API_PASSWORD=${AUTOCHECKER_API_PASSWORD}
      - AUTOCHECKER_API_LOGIN=${AUTOCHECKER_API_LOGIN}
      - AUTOCHECKER_API_BASE=${AUTOCHECKER_API_BASE}
    ports:
      - "${BACKEND_HOST_PORT:-42001}:8000"
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - lms-network
    restart: unless-stopped

  pgadmin:
    image: harbor.pg.innopolis.university/docker-hub-cache/dpage/pgadmin4:latest
    container_name: se-toolkit-lab-7-pgadmin-1
    environment:
      - PGADMIN_DEFAULT_EMAIL=${PGADMIN_EMAIL:-admin@example.com}
      - PGADMIN_DEFAULT_PASSWORD=${PGADMIN_PASSWORD:-admin}
    ports:
      - "${PGADMIN_HOST_PORT:-42003}:80"
    depends_on:
      - postgres
    networks:
      - lms-network
    restart: unless-stopped

  caddy:
    build:
      context: .
      dockerfile: frontend/Dockerfile
    container_name: se-toolkit-lab-7-caddy-1
    ports:
      - "${LMS_API_HOST_PORT:-42002}:80"
    depends_on:
      - backend
    networks:
      - lms-network
    restart: unless-stopped

  bot:
    build:
      context: .
      dockerfile: bot/Dockerfile
    container_name: se-toolkit-lab-7-bot-1
    restart: unless-stopped
    environment:
      - BOT_TOKEN=${BOT_TOKEN}
      - LMS_API_URL=http://backend:8000
      - LMS_API_KEY=${LMS_API_KEY}
      - LLM_API_KEY=${LLM_API_KEY}
      - LLM_API_BASE_URL=http://host.docker.internal:42005/v1
      - LLM_API_MODEL=${LLM_API_MODEL:-coder-model}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    depends_on:
      - backend
    networks:
      - lms-network

networks:
  lms-network:
    driver: bridge

volumes:
  postgres_data:
